// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================
// USER & AUTH
// ===========================

model User {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  password          String?
  avatarUrl         String?
  phoneNumber       String?
  currency          String    @default("USD")
  isEmailVerified   Boolean   @default(false)
  fcmToken          String?
  googleId          String?   @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  refreshTokens     RefreshToken[]
  groupMemberships  GroupMember[]
  expensesPaid      Expense[]     @relation("ExpensePayer")
  expenseSplits     ExpenseSplit[]
  settlementsFrom   Settlement[]  @relation("SettlementFrom")
  settlementsTo     Settlement[]  @relation("SettlementTo")
  activities        Activity[]
  friendsAdded      Friend[]      @relation("FriendRequester")
  friendsReceived   Friend[]      @relation("FriendReceived")
  notificationsReceived Notification[]
  commentsAdded     Comment[]
  chatMessagesSent  ChatMessage[] @relation("ChatSender")
  chatMessagesReceived ChatMessage[] @relation("ChatReceiver")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ===========================
// FRIENDS
// ===========================

model Friend {
  id          String       @id @default(uuid())
  requesterId String
  receiverId  String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  requester   User         @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    User         @relation("FriendReceived", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
}

enum FriendStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

// ===========================
// GROUPS
// ===========================

model Group {
  id          String      @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  type        GroupType   @default(OTHER)
  currency    String      @default("USD")
  createdById String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  isArchived  Boolean     @default(false)

  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  activities  Activity[]
}

enum GroupType {
  HOME
  TRIP
  COUPLE
  OTHER
}

model GroupMember {
  id       String          @id @default(uuid())
  groupId  String
  userId   String
  role     GroupMemberRole @default(MEMBER)
  joinedAt DateTime        @default(now())

  group    Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

enum GroupMemberRole {
  ADMIN
  MEMBER
}

// ===========================
// EXPENSES
// ===========================

model Expense {
  id           String        @id @default(uuid())
  title        String
  description  String?
  amount       Decimal       @db.Decimal(12, 2)
  currency     String        @default("USD")
  category     ExpenseCategory @default(OTHER)
  receiptUrl   String?
  payerId      String
  groupId      String?
  splitType    SplitType     @default(EQUAL)
  date         DateTime      @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  isDeleted    Boolean       @default(false)

  payer        User          @relation("ExpensePayer", fields: [payerId], references: [id])
  group        Group?        @relation(fields: [groupId], references: [id])
  splits       ExpenseSplit[]
  activities   Activity[]
  comments     Comment[]
}

enum ExpenseCategory {
  FOOD
  TRANSPORT
  ACCOMMODATION
  ENTERTAINMENT
  UTILITIES
  HEALTHCARE
  SHOPPING
  EDUCATION
  TRAVEL
  OTHER
}

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
  SHARES
}

model ExpenseSplit {
  id         String   @id @default(uuid())
  expenseId  String
  userId     String
  owedAmount Decimal  @db.Decimal(12, 2)
  paidAmount Decimal  @db.Decimal(12, 2) @default(0)
  isPaid     Boolean  @default(false)

  expense    Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

// ===========================
// SETTLEMENTS
// ===========================

model Settlement {
  id        String           @id @default(uuid())
  fromId    String
  toId      String
  amount    Decimal          @db.Decimal(12, 2)
  currency  String           @default("USD")
  groupId   String?
  note      String?
  method    SettlementMethod @default(CASH)
  status    SettlementStatus @default(COMPLETED)
  createdAt DateTime         @default(now())

  from      User             @relation("SettlementFrom", fields: [fromId], references: [id])
  to        User             @relation("SettlementTo", fields: [toId], references: [id])
  group     Group?           @relation(fields: [groupId], references: [id])
  activities Activity[]
}

enum SettlementMethod {
  CASH
  BANK_TRANSFER
  JAZZCASH
  EASYPAISA
  STRIPE
  OTHER
}

enum SettlementStatus {
  PENDING
  COMPLETED
  CANCELLED
}

// ===========================
// ACTIVITY & NOTIFICATIONS
// ===========================

model Activity {
  id           String       @id @default(uuid())
  type         ActivityType
  userId       String
  groupId      String?
  expenseId    String?
  settlementId String?
  metadata     Json?
  createdAt    DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  group        Group?       @relation(fields: [groupId], references: [id])
  expense      Expense?     @relation(fields: [expenseId], references: [id])
  settlement   Settlement?  @relation(fields: [settlementId], references: [id])
}

enum ActivityType {
  EXPENSE_CREATED
  EXPENSE_UPDATED
  EXPENSE_DELETED
  SETTLEMENT_CREATED
  GROUP_CREATED
  GROUP_MEMBER_ADDED
  GROUP_MEMBER_REMOVED
  FRIEND_ADDED
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  body      String
  type      NotificationType
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  EXPENSE_ADDED
  EXPENSE_UPDATED
  PAYMENT_RECEIVED
  PAYMENT_SENT
  FRIEND_REQUEST
  GROUP_INVITE
  REMINDER
}

// ===========================
// COMMENTS
// ===========================

model Comment {
  id        String   @id @default(uuid())
  expenseId String
  userId    String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ===========================
// CHAT MESSAGES
// ===========================

model ChatMessage {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  text       String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender     User     @relation("ChatSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ChatReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, senderId])
}
